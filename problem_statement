## 4. Core Algorithms

```javascript
// algorithms/deadlockDetection.js
// Detects cycles in the RAG using DFS
// Returns array of node IDs involved in deadlock (empty = no deadlock)
export function detectDeadlock(processes, resources, edges) {
  const adj = {};
  [...processes, ...resources].forEach(n => (adj[n.id] = []));
  edges.forEach(({ from, to }) => adj[from].push(to));

  const visited = new Set(), recStack = new Set(), cycle = [];

  function dfs(nodeId) {
    visited.add(nodeId);
    recStack.add(nodeId);
    for (const neighbor of adj[nodeId] || []) {
      if (!visited.has(neighbor) && dfs(neighbor)) return true;
      if (recStack.has(neighbor)) {
        cycle.push(neighbor); // collect cycle members
        return true;
      }
    }
    recStack.delete(nodeId);
    return false;
  }

  // Only initiate DFS from process nodes (convention)
  for (const p of processes) {
    if (!visited.has(p.id)) dfs(p.id);
  }
  return [...new Set(cycle)];
}

// algorithms/bankersAlgorithm.js
// Returns { safe: boolean, safeSequence: string[], steps: StepLog[] }
export function bankersAlgorithm(processes, available, allocation, need) {
  const n = processes.length, m = available.length;
  const work = [...available];
  const finish = new Array(n).fill(false);
  const safeSequence = [], steps = [];

  let found = true;
  while (found) {
    found = false;
    for (let i = 0; i < n; i++) {
      if (!finish[i] && need[i].every((ni, j) => ni <= work[j])) {
        steps.push({
          message: `Process ${processes[i].id} can proceed — Need ≤ Work`,
          highlightProcess: processes[i].id,
          workSnapshot: [...work],
        });
        work.forEach((_, j) => (work[j] += allocation[i][j]));
        finish[i] = true;
        safeSequence.push(processes[i].id);
        found = true;
      }
    }
  }

  const safe = finish.every(Boolean);
  if (!safe) steps.push({ message: 'No safe sequence found — UNSAFE STATE', highlightProcess: null });
  return { safe, safeSequence, steps };
}

// algorithms/recovery.js
// Strategy 1: terminate process with most resources
export function recoverByTermination(processes, deadlockedIds, allocationMatrix) {
  const candidates = processes.filter(p => deadlockedIds.includes(p.id));
  candidates.sort((a, b) => {
    const sumA = allocationMatrix[a.id]?.reduce((s, v) => s + v, 0) || 0;
    const sumB = allocationMatrix[b.id]?.reduce((s, v) => s + v, 0) || 0;
    return sumB - sumA; // highest resource holder first
  });
  return candidates[0]; // terminate this one
}
```

