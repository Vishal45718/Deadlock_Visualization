// models/Process.ts
interface Process {
  id: string;           // "P1", "P2"...
  label: string;
  x: number; y: number; // canvas position
  state: 'running' | 'waiting' | 'deadlocked' | 'terminated';
  allocation: number[]; // how many of each resource it holds
  request: number[];    // how many of each resource it needs
  maxDemand: number[];  // Banker's: max it will ever need
}

// models/Resource.ts
interface Resource {
  id: string;           // "R1", "R2"...
  label: string;
  x: number; y: number;
  totalInstances: number;
  availableInstances: number;
}

// models/GraphState.ts
interface GraphState {
  processes: Process[];
  resources: Resource[];
  // Adjacency: edges[fromId] = [toId, ...]
  // Allocation edge: Resource -> Process (R holds P)
  // Request edge: Process -> Resource (P wants R)
  edges: { from: string; to: string; type: 'allocation' | 'request' }[];
  available: number[];         // available[j] = instances of R_j free
  allocationMatrix: number[][]; // [process][resource]
  requestMatrix: number[][];    // [process][resource]
  maxMatrix: number[][];        // [process][resource] (for Banker's)
}
