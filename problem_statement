## 5. Key React Hooks

```javascript
// hooks/useGraph.js
import { useState, useCallback } from 'react';
import { detectDeadlock } from '../algorithms/deadlockDetection';

export function useGraph() {
  const [state, setState] = useState({
    processes: [], resources: [], edges: [],
    available: [], allocationMatrix: {}, requestMatrix: {}
  });

  const addProcess = useCallback((x, y) => {
    setState(s => {
      const id = `P${s.processes.length + 1}`;
      return { ...s, processes: [...s.processes, { id, label: id, x, y, state: 'running' }] };
    });
  }, []);

  const addResource = useCallback((x, y, instances = 1) => {
    setState(s => {
      const id = `R${s.resources.length + 1}`;
      return { ...s, resources: [...s.resources, { id, label: id, x, y, totalInstances: instances, availableInstances: instances }] };
    });
  }, []);

  const addEdge = useCallback((from, to, type) => {
    setState(s => {
      const newEdges = [...s.edges, { from, to, type }];
      const deadlocked = detectDeadlock(s.processes, s.resources, newEdges);
      const updatedProcesses = s.processes.map(p => ({
        ...p, state: deadlocked.includes(p.id) ? 'deadlocked' : 'running'
      }));
      return { ...s, edges: newEdges, processes: updatedProcesses };
    });
  }, []);

  return { state, addProcess, addResource, addEdge };
}
```

